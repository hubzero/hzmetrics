# hzmetrics unified per-tenant config.
#
# Install paths (in resolution order, high → low):
#   -c FILE flag                              — explicit, multi-tenant
#   $HZMETRICS_CONFIG                         — env override
#   /opt/hubzero/metrics/conf/hzmetrics.conf  — default, single-tenant
#
# Single-tenant operators drop this file at the default path and the
# pipeline finds it without any flag.  Multi-tenant operators put each
# tenant's config under /etc/hzmetrics/<hub>.conf and use -c (one cron
# line per tenant).  Mode 0600 root:apache either way — it carries the
# DB password.  Required for every subcommand that touches DB, DNS, or
# any site-name-derived path.
#
# Inspect effective settings with:  hzmetrics.py status

[hub]
# Site/hub name — woven into staged-log filename patterns
# (`${site}-access*log*`) and used in operator-facing log messages.
# Required.
site = theghub

# CMS document root.  Used by `whoisonline` to locate the Google Maps
# widget's XML output dir (`<hub_dir>/app/site/stats/maps/`).  Required.
hub_dir = /var/www/theghub

[db]
# Credentials for both the hub DB (read-mostly) and the metrics DB
# (read/write).  Same MariaDB instance, same user.  Required.
host = localhost
user = vhub
password = REPLACE_ME

# Hub DB name (read for jos_session, jos_resources, etc.) and the
# table-name prefix the CMS uses.  Required.
hub_db = vhub
hub_db_prefix = jos_

# Metrics DB name (read/write, owned end-to-end by the pipeline).
# Required.
metrics_db = vhub_metrics

[dns]
# Reverse-DNS resolver for `resolve-dns`.  Optional — built-in defaults
# (system resolver, c=100, t=2.0s) work without this section.
# Precedence (low → high): built-in → this file → HZMETRICS_DNS_* env
# → CLI flag.
#
#   nameserver  `system` to use /etc/resolv.conf; or an IP (local or
#               central unbound).  unbound absorbs higher concurrency
#               safely; direct-to-system above ~100 regressed in
#               benchmarking.
#   concurrency Max in-flight aiodns queries.  100 is the safe ceiling
#               against the system resolver; 500 is recommended once a
#               local or central unbound is in front.
#   timeout     Per-query seconds.  Below ~1.0s loses slow legitimate
#               resolutions; above ~3.0s just delays no-PTR detection.
nameserver = system
concurrency = 100
timeout = 2.0
