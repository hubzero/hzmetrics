# hzmetrics.py optional configuration overrides
#
# Install path:  /etc/hubzero-metrics/hzmetrics.conf
# Owner:         root:apache  (mode 640)
#
# This file is OPTIONAL.  hzmetrics.py works fine without it; values here
# override the built-in defaults.  Precedence (lowest to highest):
#     built-in defaults  →  this file  →  HZMETRICS_DNS_* env vars  →  CLI flags
#
# Inspect effective settings with:  hzmetrics.py status

[dns]
# Where the resolve-dns subcommand should send queries.
#
#   system        Use /etc/resolv.conf (no override).  Default — works on
#                 any host without extra setup.  Polite to upstream because
#                 the concurrency default below stays under typical
#                 system-resolver rate-limit thresholds.
#
#   127.0.0.1     Local unbound on this host.  Requires `dnf install
#                 unbound` plus a tuned drop-in at
#                 /etc/unbound/conf.d/hzmetrics.conf.  With local unbound
#                 deployed you can raise concurrency safely.
#
#   <internal-IP> Central hubzero unbound shared across hubs.
nameserver = system

# Max parallel in-flight aiodns queries.
#
#   100   Safe ceiling against the system resolver — benchmarked clean
#         against Purdue's 128.210.11.5/.57.  Default.
#   500   Recommended once a local or central unbound is in front.
#         Direct-to-system regressed at this level in benchmarking;
#         unbound absorbs the burst cleanly.
#  1000   No empirical gain over 500 — diminishing returns.
concurrency = 100

# Per-query timeout in seconds.  Below ~1.0 starts to lose legitimate
# slow resolutions; above ~3.0 just delays no-PTR detection without
# helping anything.
timeout = 2.0
