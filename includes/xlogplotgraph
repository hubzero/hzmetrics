use strict;

#--- Set system command paths...
#$ENV{'PATH'} = '/opt/gnuplot/bin:/opt/netpbm/bin:/opt/sfw/bin:/bin:/usr/bin:/usr/local/bin';
#$ENV{'LD_LIBRARY_PATH'} = '/opt/gd/lib:/opt/sfw/lib:/opt/usr.local/lib';
