	gnuplot    => 'gnuplot',
	pstopnm    => 'pstopnm',
	jpegtopnm  => 'jpegtopnm',
	ppmtogif   => 'ppmtogif',
	ppmtojpeg  => 'ppmtojpeg',
	ps2pdf     => 'ps2pdf',
	pnmflip    => 'pnmflip',
	pnmcrop    => 'pnmcrop',
	pnmcut     => 'pnmcut',
	pnmmargin  => 'pnmmargin',
	ppmquant   => 'ppmquant',
	rm         => 'rm',
);

#--- Read command-line arguments...
