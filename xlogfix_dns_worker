#!/usr/bin/php
<?php
# =========================================================================
# This script resolves host fields from ip address fields in various tables
#
# USAGE: ./xlogfix_dns_worker <database> <table> <startdate> <enddate>
#
# =========================================================================
# AUTHOR: Swaroop Shivarajapura S, Purdue University
